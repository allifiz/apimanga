NODE_ENV=production
HOST=127.0.0.1
PORT=4000
SANKA_BASE_URL=https://www.sankavollerei.web.id
SANKA_PROVIDER=bacakomik
SANKA_MAX_REQUESTS_PER_MINUTE=30
SANKA_TIMEOUT_MS=15000
CACHE_DB_PATH=./data/cache.sqlite
TTL_LATEST=600
TTL_POPULAR=3600
TTL_TOP=3600
TTL_RECOMMENDED=3600
TTL_GENRES=86400
TTL_GENRE=3600
TTL_SEARCH=1800
TTL_DETAIL=21600
TTL_CHAPTER=604800
PUBLIC_RATE_LIMIT_MAX=120
PUBLIC_RATE_LIMIT_WINDOW=1 minute
